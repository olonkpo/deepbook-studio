# ─────────────────────────────────────────────────────────────────────────────
# DeepBook Studio — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub. It is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend Server ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── DeepSeek AI (Default Provider) ───────────────────────────────────────────
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── Ollama (Offline Fallback) ─────────────────────────────────────────────────
# Ollama runs locally. Install from: https://ollama.com
# Default port — only change if you've configured Ollama differently.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

# ── App Settings ──────────────────────────────────────────────────────────────
# Default AI provider: 'deepseek' | 'ollama' | 'auto'
DEFAULT_AI_PROVIDER=deepseek
