# ─────────────────────────────────────────────────────────────────────────────
# DeepBook Studio — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub. It is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend Server ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── DeepSeek AI (Default Provider) ───────────────────────────────────────────
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1   # override only if using a proxy

# ── OpenRouter (multi-model gateway) ─────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Ollama (Offline Fallback) ─────────────────────────────────────────────────
# Ollama runs locally. Install from: https://ollama.com
# Default port — only change if you've configured Ollama differently.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

# ── App Settings ──────────────────────────────────────────────────────────────
# Default AI provider: 'deepseek' | 'openai' | 'openrouter' | 'claude' | 'gemini' | 'ollama' | 'auto'
DEFAULT_AI_PROVIDER=deepseek
